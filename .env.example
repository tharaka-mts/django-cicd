# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,myapp.duckdns.org
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,https://myapp.duckdns.org

# Database
DB_NAME=notesdb
DB_USER=notesuser
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# AWS / S3
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_PREFIX=uploads/

# Frontend (build-time)
VITE_API_BASE_URL=/api

# Nginx prod template variable
DOMAIN_NAME=myapp.duckdns.org
